# Obbligatori
DISCORD_TOKEN=il-tuo-bot-token
DISCORD_CHANNEL_ID=123456789012345678

# Opzionali
GEMINI_API_KEY=la-tua-chiave-gemini
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001
# SUMMARY_LANGUAGE=it
# STATE_DB_PATH=state.db

# Curatela AI del digest (richiede GEMINI_API_KEY).
# ENABLE_AI_CURATION=true
# AI_CURATION_MIN_SCORE=70
# AI_CURATION_CONCURRENCY=1
# AI_CURATION_MIN_INTERVAL_SECONDS=13.0

# Orari fissi UTC per le pubblicazioni (override dell'intervallo 12h).
# Esempio: "07:00,19:00" = due cicli al giorno, alle 07:00 e 19:00 UTC.
# FETCH_TIMES_UTC=

# Cadenza e finestra (default: 12h / 12h). Ignorati se FETCH_TIMES_UTC e' impostato.
# FETCH_INTERVAL_HOURS=12
# LOOKBACK_HOURS=12

# Retention storage (giorni).
# STATE_TTL_DAYS=14
# FEEDBACK_TTL_DAYS=45

# Watchdog: se il gateway Discord resta chiuso piu' di N secondi, il processo
# termina (Fly riavvia la VM). Default 600s.
# WATCHDOG_MAX_DOWN_SECONDS=600
